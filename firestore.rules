rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🔹 Media Gallery (images/videos)
    match /admin_uploads/{adminUid}/items/{itemId} {
      // Customers: only published media
      allow read: if request.auth != null && resource.data.status == "published";

      // Admins/collaborators: full access
      allow read, write: if request.auth != null &&
        (request.auth.uid == adminUid ||
         request.auth.uid in get(/databases/$(database)/documents/admin_uploads/$(adminUid)).data.collaborators);
    }

    // 🔹 Catalog (products)
    match /admin_uploads/{adminUid}/catalog/{productId} {
      // Customers: only published products
      allow read: if request.auth != null && resource.data.status == "published";

      // Admins/collaborators: full access
      allow read, write: if request.auth != null &&
        (request.auth.uid == adminUid ||
         request.auth.uid in get(/databases/$(database)/documents/admin_uploads/$(adminUid)).data.collaborators);
    }
  }
}









